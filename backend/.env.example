# Strat Edge Portal - Environment Configuration

# 1. DATABASE
# For SQLite (Local):
# DATABASE_URL=sqlite:///../../pmt_app/pm_tool.db
# For Neon/PostgreSQL (Production):
# DATABASE_URL=postgresql://user:password@your-neon-host/dbname?sslmode=require

# 2. SECURITY
SECRET_KEY=generate-a-long-random-string-here
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 3. GOOGLE CLOUD STORAGE (GCP)
GCP_PROJECT_ID=custom-mix-428318-h3
GCP_BUCKET_NAME=stratedgestore
# Path to your JSON credentials file (relative to backend folder)
GOOGLE_APPLICATION_CREDENTIALS=gcp-credentials.json

# 4. CORS (Frontend URL)
# CORS_ORIGINS=["http://localhost:3000", "https://your-frontend.render.com"]
